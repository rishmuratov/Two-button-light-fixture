PROGRAM PLC_PRG
VAR
	button_On : BOOL; (*вкл*)
	button_Off : BOOL; (*выкл*)
	lamp : BOOL; (*лампочка*)
	buttonOnOld : BOOL; (*запоминает предыдущее положение вкл*)
	buttonOffOld : BOOL; (*запоминает предыдущее положение выкл*)
END_VAR

// !!! УДАЛИТЕ НЕИСПОЛЬЗУЕМЫЕ ИНТЕРФЕЙСЫ (RS-485, RS-232, Ethernet) ИЗ ПРОЕКТА !!!
IF button_On AND NOT buttonOnOld THEN
	lamp := TRUE;   (* переключаем лампочку *)
END_IF

IF button_Off AND NOT buttonOffOld THEN
	lamp := FALSE;   (* переключаем лампочку *)
END_IF

buttonOnOld := button_On;
buttonOffOld := button_Off;


